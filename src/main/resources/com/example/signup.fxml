<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="root"
           xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.controllers.SignupController">

    <!-- 🔹 Background Image -->
    <ImageView fx:id="backgroundImage" preserveRatio="false">
        <image>
            <Image url="@images/train.png"/>
        </image>
    </ImageView>

    <!-- 🔹 Optional dark overlay (improves contrast) -->
    

    <!-- 🔹 Glass Card -->
    <StackPane alignment="CENTER">

        <VBox alignment="CENTER" spacing="20" maxWidth="380" maxHeight="500"
              style="-fx-background-color: rgba(255, 255, 255, 0.29);
                     -fx-background-radius: 25;
                     -fx-border-color: rgba(255, 255, 255, 0.61);
                     -fx-border-radius: 25;
                     -fx-effect: dropshadow(gaussian, rgba(182, 182, 182, 0.42), 20, 0.3, 0, 10);">

            <padding>
                <Insets top="30" bottom="30" left="25" right="25"/>
            </padding>

            <!-- 🔹 Title -->
            <Label text="Create an Account" textFill="black">
                <font>
                    <Font size="34"/>
                </font>
            </Label>

            <!-- 🔹 Input Fields -->
            <VBox spacing="15">

                <TextField fx:id="emailField" promptText="Email"
                           style="-fx-background-color: rgba(255,255,255,0.4);
                                  -fx-background-radius: 20;
                                  -fx-text-fill: black;
                                  -fx-prompt-text-fill: #555;
                                  -fx-padding: 10 15;"/>

                <TextField fx:id="usernameField" promptText="Username"
                           style="-fx-background-color: rgba(255,255,255,0.4);
                                  -fx-background-radius: 20;
                                  -fx-text-fill: black;
                                  -fx-prompt-text-fill: #555;
                                  -fx-padding: 10 15;"/>

                <PasswordField fx:id="passwordField" promptText="Password"
                               style="-fx-background-color: rgba(255,255,255,0.4);
                                      -fx-background-radius: 20;
                                      -fx-text-fill: black;
                                      -fx-prompt-text-fill: #555;
                                      -fx-padding: 10 15;"/>

            </VBox>

            <!-- 🔹 Buttons -->
            <HBox alignment="CENTER" spacing="15">

                <Button text="Back"
                    onAction="#goBackToLogin"
                    styleClass="back-button"/>

                <Button text="Sign Up"
                    styleClass="signup-button"
                    onAction="#handleSignup"/>

            </HBox>
            <Label fx:id="errorLabel"
                text=""
                textFill="red"
                visible="false"/>

        </VBox>

    </StackPane>

</StackPane>