<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns:fx="http://javafx.com/fxml" stylesheets="@style.css">
    <!-- TOP NAVBAR -->
    <top>
        <HBox spacing="10" styleClass="navbar">
            <Button text="Home" styleClass="nav-button"/>
            <Button text="Railway" styleClass="nav-button"/>
            <Button text="Air" styleClass="nav-button"/>
            <Button text="Events" styleClass="nav-button"/>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="20" alignment="TOP_LEFT" style="-fx-padding: 30;">
            
            <Label text="Welcome to Reservation System" styleClass="title"/>

            <HBox spacing="20">
                
                <VBox styleClass="card">
                    <Label text="🚆 Upcoming trains"/>
                </VBox>

                <VBox styleClass="card">
                    <Label text="✈️ Upcoming flights"/>
                </VBox>

                <VBox styleClass="card">
                    <Label text="🎫 Events near you"/>
                </VBox>

            </HBox>

        </VBox>
    </center>

</BorderPane>