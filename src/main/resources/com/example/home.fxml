<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<StackPane fx:id="root"
            xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.controllers.HomeController">

    <!-- 🔹 Background Image -->
    <ImageView fx:id="backgroundImage" preserveRatio="false">
        <image>
            <Image url="@images/train.png"/>
        </image>
    </ImageView>


    <!-- 🔹 Main Layout -->
    <BorderPane>

        <!-- 🔝 Top Navbar -->
        <top>
            <HBox alignment="CENTER_LEFT" spacing="15"
                  style="-fx-background-color: rgba(255,255,255,0.2);
                         -fx-padding: 10 15;
                         -fx-border-color: rgba(255,255,255,0.4);
                         -fx-border-width: 0 0 1 0;">

                <Label text="TicketRes"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Railway" onAction="#loadRailwayView" styleClass="nav-button"/>
                <Button text="Planes" onAction="#loadPlaneView" styleClass="nav-button"/>
                <Button text="Events" onAction="#loadEventView" styleClass="nav-button"/>

                <Button text="Logout" onAction="#handleLogout" styleClass="danger-button"/>
            </HBox>
        </top>

        <!-- 🔽 Center Content -->
        <center>
            <StackPane alignment="CENTER">

                <!-- 🔥 Glass Card -->
                <VBox spacing="15" maxWidth="700"
                      style="-fx-background-color: rgba(255,255,255,0.25);
                             -fx-background-radius: 25;
                             -fx-border-color: rgba(255,255,255,0.6);
                             -fx-border-radius: 25;
                             -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 20, 0.3, 0, 10);">

                    <!-- Title -->
                    <Label text="Available Routes"
                           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: black;"/>

                    <!-- Table -->
                    <TableView fx:id="routeTable" prefHeight="400">

                        <columns>
                            <TableColumn text="ID" fx:id="colId" prefWidth="50"/>
                            <TableColumn text="From" fx:id="colSource" prefWidth="120"/>
                            <TableColumn text="To" fx:id="colDestination" prefWidth="120"/>
                            <TableColumn text="Type" fx:id="colType" prefWidth="100"/>
                            <TableColumn text="Seats" fx:id="colSeats" prefWidth="80"/>
                            <TableColumn text="Price" fx:id="colPrice" prefWidth="100"/>
                        </columns>

                    </TableView>

                </VBox>

            </StackPane>
        </center>

    </BorderPane>

</StackPane>